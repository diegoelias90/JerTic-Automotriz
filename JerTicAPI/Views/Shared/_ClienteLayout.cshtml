<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Jertic Automotriz</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg:       #0C0C14;
            --surface:  #13131E;
            --card:     #1A1A28;
            --border:   #2A2A3E;
            --accent:   #FFA500;
            --accent2:  #FF7A00;
            --text:     #E8E8F0;
            --muted:    #7070A0;
            --success:  #3CB371;
            --danger:   #E05555;
            --r:        10px;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg); color: var(--text);
            min-height: 100vh;
        }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

        /* ── NAV ── */
        .nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 50;
            height: 62px;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 40px;
            background: rgba(12,12,20,0.88); backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
        }
        .nav-brand {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 26px; letter-spacing: 3px; color: var(--accent);
            text-decoration: none;
        }
        .nav-brand span { color: var(--text); }
        .nav-links { display: flex; gap: 2px; }
        .nav-link {
            color: var(--muted); text-decoration: none;
            font-size: 13.5px; font-weight: 500;
            padding: 7px 15px; border-radius: 8px; transition: all .2s;
        }
        .nav-link:hover, .nav-link.active { color: var(--text); background: var(--card); }
        .nav-right { display: flex; gap: 8px; align-items: center; }
        .btn-nav-ghost {
            background: none; border: 1px solid var(--border); color: var(--text);
            font-family: 'DM Sans',sans-serif; font-size: 13px; font-weight: 500;
            padding: 7px 18px; border-radius: 8px; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center; transition: all .2s;
        }
        .btn-nav-ghost:hover { border-color: var(--accent); color: var(--accent); }
        .btn-nav-solid {
            background: var(--accent); border: none; color: #0c0c14;
            font-family: 'DM Sans',sans-serif; font-size: 13px; font-weight: 600;
            padding: 7px 18px; border-radius: 8px; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center; transition: all .2s;
        }
        .btn-nav-solid:hover { background: var(--accent2); transform: translateY(-1px); }
        .nav-user-chip {
            font-size: 13px; font-weight: 500; color: var(--text);
            padding: 6px 14px; background: var(--card); border-radius: 8px;
            border: 1px solid var(--border);
        }

        /* ── MAIN ── */
        .main { padding-top: 62px; min-height: 100vh; }

        /* ── PAGE HEADER ── */
        .page-header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 44px 52px 32px;
        }
        .page-tag {
            font-family: 'DM Mono', monospace; font-size: 10px; font-weight: 500;
            color: var(--accent); letter-spacing: 2.5px; text-transform: uppercase;
            margin-bottom: 8px;
        }
        .page-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 46px; letter-spacing: 3px; line-height: 1;
        }
        .page-sub { color: var(--muted); font-size: 14px; margin-top: 6px; font-weight: 300; }
        .page-body { padding: 40px 52px; }

        /* ── BOTONES ── */
        .btn {
            display: inline-flex; align-items: center; gap: 6px;
            font-family: 'DM Sans',sans-serif; font-weight: 600; font-size: 13.5px;
            padding: 10px 24px; border-radius: var(--r); border: none;
            cursor: pointer; transition: all .2s; text-decoration: none;
        }
        .btn-primary { background: var(--accent); color: #0c0c14; }
        .btn-primary:hover { background: var(--accent2); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(255,165,0,.25); }
        .btn-primary:disabled { opacity: .5; cursor: not-allowed; transform: none; box-shadow: none; }
        .btn-secondary { background: var(--card); color: var(--text); border: 1px solid var(--border); }
        .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
        .btn-danger { background: rgba(224,85,85,.1); color: #e08888; border: 1px solid rgba(224,85,85,.25); }
        .btn-danger:hover { background: rgba(224,85,85,.2); }
        .btn-lg { padding: 13px 32px; font-size: 15px; }
        .btn-full { width: 100%; justify-content: center; }

        /* ── FORMULARIO ── */
        .form-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 14px; padding: 36px 40px; max-width: 700px;
        }
        .form-card-title {
            font-family: 'Bebas Neue',sans-serif; font-size: 30px;
            letter-spacing: 2px; margin-bottom: 4px;
        }
        .form-card-sub { font-size: 13px; color: var(--muted); margin-bottom: 28px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 18px; }
        .form-row.single { grid-template-columns: 1fr; }
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-group.col2 { grid-column: span 2; }
        .form-label {
            font-size: 11px; font-weight: 600; letter-spacing: 1.2px;
            text-transform: uppercase; color: var(--muted);
        }
        .form-control {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 8px; padding: 10px 14px;
            color: var(--text); font-family: 'DM Sans',sans-serif; font-size: 14px;
            outline: none; transition: border-color .2s; width: 100%;
        }
        .form-control:focus { border-color: var(--accent); }
        .form-control::placeholder { color: var(--muted); opacity: .6; }
        .form-control.input-error { border-color: var(--danger); }
        select.form-control { cursor: pointer; }
        textarea.form-control { resize: vertical; min-height: 100px; }
        .field-error { font-size: 11.5px; color: #e08888; margin-top: 2px; }
        .form-actions { margin-top: 24px; display: flex; gap: 10px; }

        /* ── ALERTAS ── */
        .alert {
            display: flex; align-items: flex-start; gap: 10px;
            padding: 12px 16px; border-radius: var(--r); margin-bottom: 20px;
            font-size: 13.5px; line-height: 1.5;
        }
        .alert-error   { background: rgba(224,85,85,.08); border: 1px solid rgba(224,85,85,.25); color: #e08888; }
        .alert-success { background: rgba(60,179,113,.08); border: 1px solid rgba(60,179,113,.25); color: #5dd68a; }
        .alert-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
        .alert-error   .alert-dot { background: var(--danger); }
        .alert-success .alert-dot { background: var(--success); }

        /* ── ESTADO BADGES ── */
        .badge {
            display: inline-block; font-size: 10.5px; font-weight: 600;
            letter-spacing: 1px; text-transform: uppercase;
            padding: 3px 11px; border-radius: 100px;
        }
        .estado-pendiente  { background: rgba(120,120,160,.12); color: var(--muted);  border: 1px solid rgba(120,120,160,.2); }
        .estado-programada { background: rgba(80,140,255,.12);  color: #7ab4ff; border: 1px solid rgba(80,140,255,.25); }
        .estado-proceso    { background: rgba(255,165,0,.12);   color: var(--accent); border: 1px solid rgba(255,165,0,.25); }
        .estado-finalizado { background: rgba(60,179,113,.12);  color: #5dd68a; border: 1px solid rgba(60,179,113,.25); }
        .estado-cancelada  { background: rgba(224,85,85,.12);   color: #e08888; border: 1px solid rgba(224,85,85,.25); }

        /* ── TABS ── */
        .tabs { display: flex; gap: 4px; margin-bottom: 28px; border-bottom: 1px solid var(--border); padding-bottom: 0; }
        .tab-btn {
            background: none; border: none; border-bottom: 2px solid transparent;
            color: var(--muted); font-family: 'DM Sans',sans-serif; font-size: 13.5px;
            font-weight: 500; padding: 10px 20px; cursor: pointer;
            transition: all .2s; margin-bottom: -1px;
        }
        .tab-btn:hover { color: var(--text); }
        .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); font-weight: 600; }
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        /* ── PRODUCTOS ── */
        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px,1fr)); gap: 14px; }
        .product-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 12px; padding: 22px; transition: all .25s;
        }
        .product-card:hover { border-color: rgba(255,165,0,.3); transform: translateY(-3px); }
        .product-tipo {
            font-size: 10px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;
            color: var(--accent); margin-bottom: 12px;
            padding: 3px 10px; background: rgba(255,165,0,.08);
            border: 1px solid rgba(255,165,0,.15); border-radius: 100px;
            display: inline-block;
        }
        .product-name { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
        .product-desc { font-size: 12.5px; color: var(--muted); margin-bottom: 16px; line-height: 1.6; min-height: 40px; }
        .product-bottom { display: flex; justify-content: space-between; align-items: flex-end; }
        .product-price { font-family: 'DM Mono',monospace; font-size: 20px; color: var(--accent); font-weight: 500; }
        .product-stock { font-size: 11.5px; color: var(--muted); text-align: right; }
        .stock-low { color: #e08888; }

        /* ── HISTORIAL ── */
        .historial-empty { text-align: center; padding: 64px 20px; }
        .historial-empty-title {
            font-family: 'Bebas Neue', sans-serif; font-size: 26px;
            letter-spacing: 2px; color: var(--border); margin-bottom: 8px;
        }
        .historial-empty-sub { font-size: 14px; color: var(--muted); }

        .cita-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 12px; padding: 20px 24px; margin-bottom: 12px;
            display: flex; justify-content: space-between; align-items: center;
            transition: border-color .2s;
        }
        .cita-card:hover { border-color: rgba(255,165,0,.2); }
        .cita-meta { font-size: 12px; color: var(--muted); margin-bottom: 4px; font-family: 'DM Mono',monospace; }
        .cita-motivo { font-size: 14px; font-weight: 500; max-width: 480px; }

        .timeline { position: relative; padding-left: 28px; }
        .timeline::before {
            content: ''; position: absolute; left: 6px; top: 0; bottom: 0;
            width: 1px; background: var(--border);
        }
        .timeline-item { position: relative; margin-bottom: 20px; }
        .timeline-item::before {
            content: ''; position: absolute; left: -26px; top: 6px;
            width: 10px; height: 10px; border-radius: 50%;
            background: var(--surface); border: 2px solid var(--accent);
        }
        .timeline-date { font-family: 'DM Mono',monospace; font-size: 11.5px; color: var(--muted); margin-bottom: 4px; }
        .timeline-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 10px; padding: 14px 18px;
        }
        .timeline-card p { font-size: 13.5px; line-height: 1.65; }
        .timeline-card small { font-size: 11px; color: var(--muted); }

        /* ── PERFIL ── */
        .perfil-wrap { max-width: 620px; }
        .perfil-top {
            display: flex; align-items: center; gap: 20px;
            margin-bottom: 32px;
            background: var(--card); border: 1px solid var(--border);
            border-radius: 12px; padding: 24px 28px;
        }
        .perfil-avatar {
            width: 64px; height: 64px; border-radius: 50%; flex-shrink: 0;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: flex; align-items: center; justify-content: center;
            font-family: 'Bebas Neue',sans-serif; font-size: 24px; color: #0c0c14;
        }
        .perfil-fullname { font-family: 'Bebas Neue',sans-serif; font-size: 26px; letter-spacing: 1px; }
        .perfil-email { font-size: 13px; color: var(--muted); }
        .perfil-since { font-size: 11.5px; color: var(--muted); margin-top: 2px; font-family: 'DM Mono',monospace; }

        /* ── AUTH (login/registro) ── */
        .auth-wrap {
            min-height: calc(100vh - 62px);
            display: flex; align-items: center; justify-content: center;
            padding: 40px 20px;
            background:
                radial-gradient(ellipse 70% 50% at 50% -5%, rgba(255,165,0,.1) 0%, transparent 60%),
                var(--bg);
        }
        .auth-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 16px; padding: 44px 48px; width: 100%; max-width: 440px;
        }
        .auth-logo { font-family: 'Bebas Neue',sans-serif; font-size: 22px; letter-spacing: 3px; color: var(--accent); margin-bottom: 32px; }
        .auth-logo span { color: var(--text); }
        .auth-title { font-family: 'Bebas Neue',sans-serif; font-size: 36px; letter-spacing: 2px; margin-bottom: 4px; }
        .auth-sub { font-size: 13px; color: var(--muted); margin-bottom: 28px; }
        .auth-switch { text-align: center; margin-top: 22px; font-size: 13px; color: var(--muted); }
        .auth-switch a { color: var(--accent); text-decoration: none; font-weight: 500; }
        .auth-switch a:hover { text-decoration: underline; }

        /* ── FOOTER ── */
        .footer {
            border-top: 1px solid var(--border); background: var(--surface);
            padding: 28px 52px; margin-top: 60px;
            display: flex; justify-content: space-between; align-items: center;
        }
        .footer-brand { font-family: 'Bebas Neue',sans-serif; font-size: 18px; letter-spacing: 2px; color: var(--accent); }
        .footer-brand span { color: var(--muted); }
        .footer-text { font-size: 12px; color: var(--muted); }

        @@media (max-width: 768px) {
            .nav { padding: 0 18px; }
            .nav-links { display: none; }
            .page-header { padding: 32px 22px 24px; }
            .page-body { padding: 26px 22px; }
            .form-row { grid-template-columns: 1fr; }
            .form-group.col2 { grid-column: span 1; }
            .auth-card { padding: 32px 24px; }
            .footer { flex-direction: column; gap: 8px; padding: 24px 22px; text-align: center; }
        }
    </style>
</head>
<body>
    <nav class="nav">
        <a class="nav-brand" asp-controller="ClienteWeb" asp-action="Index">JERTIC<span>.</span></a>

        <div class="nav-links">
            <a class="nav-link @(ViewData["Page"]?.ToString() == "home" ? "active" : "")"
               asp-controller="ClienteWeb" asp-action="Index">Inicio</a>

            <a class="nav-link @(ViewData["Page"]?.ToString() == "productos" ? "active" : "")"
               asp-controller="ClienteWeb" asp-action="Productos">Productos</a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="nav-link @(ViewData["Page"]?.ToString() == "cita" ? "active" : "")"
                   asp-controller="ClienteWeb" asp-action="Cita">Pedir Cita</a>

                <a class="nav-link @(ViewData["Page"]?.ToString() == "historial" ? "active" : "")"
                   asp-controller="ClienteWeb" asp-action="Historial">Mi Historial</a>

                <a class="nav-link @(ViewData["Page"]?.ToString() == "perfil" ? "active" : "")"
                   asp-controller="ClienteWeb" asp-action="Perfil">Mi Perfil</a>
            }
        </div>

        <div class="nav-right">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="nav-user-chip">@User.Identity.Name</span>
                <form asp-controller="ClienteWeb" asp-action="Logout" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-nav-ghost">Cerrar sesion</button>
                </form>
            }
            else
            {
                <a class="btn-nav-ghost" asp-controller="ClienteWeb" asp-action="Login">Iniciar sesion</a>
                <a class="btn-nav-solid" asp-controller="ClienteWeb" asp-action="Registro">Crear cuenta</a>
            }
        </div>
    </nav>

    <main class="main">
        @if (TempData["Exito"] != null)
        {
            <div style="position:fixed;bottom:28px;right:28px;z-index:99;
                        background:var(--card);border:1px solid rgba(60,179,113,.35);
                        border-radius:10px;padding:13px 20px;font-size:13.5px;
                        color:#5dd68a;display:flex;gap:8px;align-items:center;
                        box-shadow:0 8px 28px rgba(0,0,0,.4);" id="toast">
                <span style="width:7px;height:7px;border-radius:50%;background:#3CB371;flex-shrink:0;display:inline-block"></span>
                @TempData["Exito"]
            </div>
            <script>setTimeout(()=>document.getElementById('toast')?.remove(), 3500)</script>
        }

        @RenderBody()
    </main>

    <footer class="footer">
        <div class="footer-brand">JERTIC<span>. AUTOMOTRIZ</span></div>
        <div class="footer-text">Taller automotriz profesional — El Salvador</div>
    </footer>
</body>
</html>
