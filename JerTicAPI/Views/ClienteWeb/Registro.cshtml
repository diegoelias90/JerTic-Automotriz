@model JerTicAPI.ViewModels.RegistroViewModel
@{
    ViewData["Title"] = "Crear cuenta";
    Layout = "~/Views/Shared/_ClienteLayout.cshtml";
}

<div class="auth-wrap" style="padding:80px 20px 40px;">
    <div class="auth-card" style="max-width:520px;">
        <div class="auth-logo">JERTIC<span>.</span></div>
        <h1 class="auth-title">Crear Cuenta</h1>
        <p class="auth-sub">Completa tus datos para registrarte. Es gratis.</p>

        @if (Model.Error != null)
        {
            <div class="alert alert-error">
                <span class="alert-dot"></span> @Model.Error
            </div>
        }

        <form asp-action="Registro" method="post">
            @Html.AntiForgeryToken()

            <div class="form-row" style="margin-bottom:16px">
                <div class="form-group">
                    <label class="form-label" asp-for="Nombre"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Tu nombre"/>
                    <span asp-validation-for="Nombre" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Apellido"></label>
                    <input asp-for="Apellido" class="form-control" placeholder="Tu apellido"/>
                    <span asp-validation-for="Apellido" class="field-error"></span>
                </div>
            </div>

            <div class="form-row single" style="margin-bottom:16px">
                <div class="form-group">
                    <label class="form-label" asp-for="Correo"></label>
                    <input asp-for="Correo" class="form-control" type="email" placeholder="correo@ejemplo.com"/>
                    <span asp-validation-for="Correo" class="field-error"></span>
                </div>
            </div>

            <div class="form-row" style="margin-bottom:16px">
                <div class="form-group">
                    <label class="form-label" asp-for="Telefono"></label>
                    <input asp-for="Telefono" class="form-control" placeholder="70000000"/>
                </div>
                <div style="display:none"></div>
            </div>

            <div class="form-row" style="margin-bottom:26px">
                <div class="form-group">
                    <label class="form-label" asp-for="Token"></label>
                    <input asp-for="Token" class="form-control" type="password" placeholder="Minimo 6 caracteres"/>
                    <span asp-validation-for="Token" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="ConfirmarToken"></label>
                    <input asp-for="ConfirmarToken" class="form-control" type="password" placeholder="Repetir contrasena"/>
                    <span asp-validation-for="ConfirmarToken" class="field-error"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full">Crear cuenta</button>
        </form>

        <div class="auth-switch">
            Ya tienes cuenta?
            <a asp-controller="ClienteWeb" asp-action="Login">Ingresar aqui</a>
        </div>
    </div>
</div>
