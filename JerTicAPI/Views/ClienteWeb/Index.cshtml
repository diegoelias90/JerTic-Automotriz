@{
    ViewData["Title"] = "Inicio";
    ViewData["Page"] = "home";
    Layout = "~/Views/Shared/_ClienteLayout.cshtml";
}

<!-- HERO -->
<section style="
    min-height: calc(100vh - 62px);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 80px 40px 60px;
    background: radial-gradient(ellipse 80% 55% at 50% -8%, rgba(255,165,0,.13) 0%, transparent 65%), #0C0C14;
    position: relative; overflow: hidden;">

    <!-- línea de fondo decorativa -->
    <div style="
        position: absolute; inset: 0; pointer-events: none;
        background-image: linear-gradient(rgba(255,165,0,.03) 1px, transparent 1px),
                          linear-gradient(90deg, rgba(255,165,0,.03) 1px, transparent 1px);
        background-size: 60px 60px;">
    </div>

    <div style="
        display: inline-flex; align-items: center; gap: 8px;
        background: rgba(255,165,0,.07); border: 1px solid rgba(255,165,0,.2);
        color: #FFA500; font-size: 11px; font-weight: 600; letter-spacing: 2.5px;
        text-transform: uppercase; padding: 6px 18px; border-radius: 100px; margin-bottom: 36px;">
        <span style="width:6px;height:6px;border-radius:50%;background:#FFA500;
                     animation:dot 2s infinite;display:inline-block"></span>
        Taller automotriz profesional
    </div>

    <h1 style="
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(68px, 11vw, 120px);
        line-height: .92; letter-spacing: 5px; margin-bottom: 28px;">
        JERTIC<br><span style="color:#FFA500">AUTOMOTRIZ</span>
    </h1>

    <p style="
        font-size: clamp(15px, 1.8vw, 19px); color: #7070A0; max-width: 540px;
        line-height: 1.75; margin-bottom: 48px; font-weight: 300;">
        Mas de 15 anos de experiencia en diagnostico, mantenimiento y reparacion de vehiculos.
        Tu auto en manos de verdaderos especialistas.
    </p>

    <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="btn btn-primary btn-lg" asp-controller="ClienteWeb" asp-action="Cita">Agendar cita ahora</a>
        }
        else
        {
            <a class="btn btn-primary btn-lg" asp-controller="ClienteWeb" asp-action="Login"
               onclick="this.href='@Url.Action("Login", "ClienteWeb", new { returnUrl = "/ClienteWeb/Cita" })'">
                Agendar cita ahora
            </a>
        }
        <a class="btn btn-secondary btn-lg" asp-controller="ClienteWeb" asp-action="Productos">Ver catalogo</a>
    </div>

    <style>
        @@keyframes dot {
            0%, 100% {
                opacity: 1;
                transform: scale(1)
            }

            50% {
                opacity: .4;
                transform: scale(.7)
            }
        }
    </style>
</section>

<!-- STATS -->
<div style="
    display: grid; grid-template-columns: repeat(4, 1fr);
    background: #13131E;
    border-top: 1px solid #2A2A3E; border-bottom: 1px solid #2A2A3E;">
    @foreach (var stat in new[] {
        new { Num = "15+",   Label = "Anos de experiencia" },
        new { Num = "2400+", Label = "Vehiculos atendidos" },
        new { Num = "12",    Label = "Tecnicos certificados" },
        new { Num = "98%",   Label = "Clientes satisfechos" }
        })
    {
        <div style="padding:32px 20px;text-align:center;border-right:1px solid #2A2A3E;">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:44px;color:#FFA500;letter-spacing:2px">
                @stat.Num
            </div>
            <div style="font-size:12.5px;color:#7070A0;margin-top:4px;font-weight:500">@stat.Label</div>
        </div>
    }
</div>

<!-- QUIENES SOMOS -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1px;background:#2A2A3E;border-top:1px solid #2A2A3E;">
    <div style="background:#13131E;padding:56px 52px;">
        <div class="page-tag">// Quienes somos</div>
        <h2 style="font-family:'Bebas Neue',sans-serif;font-size:40px;letter-spacing:2px;margin-bottom:16px;line-height:1.05">
            El taller de confianza<br>en El Salvador
        </h2>
        <p style="font-size:15px;color:#7070A0;line-height:1.85;font-weight:300">
            Jertic Automotriz nacio de la pasion por la mecanica y el compromiso con la excelencia.
            Desde nuestros inicios hemos construido una reputacion basada en honestidad, precision
            tecnica y atencion genuina al cliente. Cada vehiculo que entra a nuestro taller
            recibe el mismo nivel de cuidado, sin importar la marca o modelo.
        </p>
    </div>
    <div style="background:#13131E;padding:56px 52px;border-left:1px solid #2A2A3E;">
        <div class="page-tag">// Nuestra mision</div>
        <h2 style="font-family:'Bebas Neue',sans-serif;font-size:40px;letter-spacing:2px;margin-bottom:16px;line-height:1.05">
            Calidad sin<br>compromiso
        </h2>
        <p style="font-size:15px;color:#7070A0;line-height:1.85;font-weight:300">
            Utilizamos tecnologia de diagnostico computarizado de ultima generacion y repuestos
            certificados para garantizar que tu vehiculo reciba el mantenimiento correcto,
            a tiempo y al mejor precio del mercado. Transparencia total en cada proceso.
        </p>
    </div>
</div>

<!-- SERVICIOS -->
<section style="padding:80px 52px;background:#0C0C14;">
    <div style="text-align:center;margin-bottom:56px;">
        <div class="page-tag" style="display:block;margin-bottom:10px">// Nuestros servicios</div>
        <h2 style="font-family:'Bebas Neue',sans-serif;font-size:52px;letter-spacing:3px;">
            Lo que hacemos mejor
        </h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;max-width:1100px;margin:0 auto;">
        @foreach (var svc in new[] {
                new { Icon = "M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18",
                Title = "Diagnostico Computarizado",
                Desc  = "Lectura de codigos de falla con equipo certificado. Identificamos el problema desde la primera revision." },
                new { Icon = "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
                Title = "Mantenimiento Preventivo",
                Desc  = "Cambios de aceite, filtros y bujias. Mantene tu vehiculo en optimas condiciones antes de que surjan problemas." },
                new { Icon = "M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z",
                Title = "Reparacion Mecanica",
                Desc  = "Motor, transmision, frenos y suspension. Reparamos cualquier falla con repuestos originales y garantia." },
                new { Icon = "M13 10V3L4 14h7v7l9-11h-7z",
                Title = "Electricidad Automotriz",
                Desc  = "Diagnostico del sistema electrico, bateria, alternador e instalacion de accesorios." },
                new { Icon = "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
                Title = "Inspeccion de Seguridad",
                Desc  = "Revision completa de 50 puntos. Viaja con la tranquilidad de saber que tu vehiculo esta en condiciones." },
                new { Icon = "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2",
                Title = "Seguimiento Online",
                Desc  = "Agenda tu cita y consulta el historial completo de servicios de tu vehiculo desde esta plataforma." }
                })
        {
            <div style="
                    background:#1A1A28;border:1px solid #2A2A3E;
                    border-radius:12px;padding:32px 26px;
                    transition:all .25s;position:relative;overflow:hidden;"
                 onmouseenter="this.style.borderColor='rgba(255,165,0,.35)';this.style.transform='translateY(-4px)'"
                 onmouseleave="this.style.borderColor='#2A2A3E';this.style.transform='translateY(0)'">
                <div style="
                        width:46px;height:46px;border-radius:10px;
                        background:rgba(255,165,0,.08);border:1px solid rgba(255,165,0,.18);
                        display:flex;align-items:center;justify-content:center;margin-bottom:18px;">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
                         stroke="#FFA500" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="@svc.Icon" />
                    </svg>
                </div>
                <h3 style="font-size:15px;font-weight:600;margin-bottom:9px">@svc.Title</h3>
                <p style="font-size:13px;color:#7070A0;line-height:1.7">@svc.Desc</p>
            </div>
        }
    </div>
</section>

<!-- CTA FINAL -->
@if (User.Identity?.IsAuthenticated != true)
{
    <section style="
            background:#13131E;border-top:1px solid #2A2A3E;
            padding:80px 52px;text-align:center;">
        <div class="page-tag" style="display:block;margin-bottom:12px">// Comenza hoy</div>
        <h2 style="font-family:'Bebas Neue',sans-serif;font-size:52px;letter-spacing:3px;margin-bottom:14px">
            Tu vehículo merece el mejor cuidado
        </h2>
        <p style="font-size:16px;color:#7070A0;margin-bottom:40px;font-weight:300">
            Crea tu cuenta gratis y agenda tu primera cita en menos de 2 minutos.
        </p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
            <a class="btn btn-primary btn-lg" asp-controller="ClienteWeb" asp-action="Registro">Crear cuenta gratis</a>
            <a class="btn btn-secondary btn-lg" asp-controller="ClienteWeb" asp-action="Login">Ya tengo cuenta</a>
        </div>
    </section>
}
